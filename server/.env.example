# Copy to .env and fill in.

# OpenAI key — used only inside the four LLM functions in src/llm.ts
OPENAI_API_KEY=sk-your-key

# Postgres connection string (Neon works well: https://neon.tech)
# Stores: uploaded PDFs, lesson state (read model), and Mastra workflow run snapshots.
DATABASE_URL=postgresql://user:password@host/db?sslmode=require
